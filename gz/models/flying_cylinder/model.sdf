<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="flying_cylinder">
    <static>false</static>
    <pose>0 0 0 0 0 0</pose>

    <!-- Main body -->
    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>

      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.05</ixx>
          <iyy>0.05</iyy>
          <izz>0.02</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://flying_cylinder/meshes/cylinder.dae</uri>
          </mesh>
        </geometry>
      </collision>

      <visual name="base_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://flying_cylinder/meshes/cylinder.dae</uri>
          </mesh>
        </geometry>
		<material>
		  <ambient>0.85 0.7 0.95 1</ambient>
		  <diffuse>0.85 0.7 0.95 1</diffuse>
		  <specular>0.1 0.1 0.1 1</specular>
		</material>
      </visual>

      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <visualize>true</visualize>
        <topic>imu</topic>
      </sensor>
    </link>

    <!-- Rotor 0-->
    <link name="rotor_0">
      <pose>0 0 0 0 0 0</pose>

      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.002</ixx>
          <iyy>0.002</iyy>
          <izz>0.004</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="rotor_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://flying_cylinder/meshes/propellerCCW.dae</uri>
          </mesh>
        </geometry>
      </collision>

      <visual name="rotor_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://flying_cylinder/meshes/propellerCCW.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.7 0.95 0.85 1</ambient>
          <diffuse>0.7 0.95 0.85 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
          <damping>0.001</damping>
        </dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- Rotor 1-->
    <link name="rotor_1">
      <pose>0 0 0 0 0 0</pose>

      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.002</ixx>
          <iyy>0.002</iyy>
          <izz>0.004</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="rotor_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
         <mesh>
            <uri>model://flying_cylinder/meshes/propellerCW.dae</uri>
          </mesh>
        </geometry>
      </collision>

      <visual name="rotor_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://flying_cylinder/meshes/propellerCW.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.95 0.7 0.8 1</ambient>
          <diffuse>0.95 0.7 0.8 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
          <damping>0.001</damping>
        </dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>
    
  </model>
</sdf>